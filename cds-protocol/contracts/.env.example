# Example environment for deploying and running the CDS contracts and keeper
# Copy this to .env and fill values before running deploy scripts or the keeper bot.

# --- Keys ---
# Private key used for forge deployments (hex, 0x...)
PRIVATE_KEY=

# Keeper bot (automation) private key used to sign txs (hex, 0x...)
KEEPER_PRIVATE_KEY=

# --- RPC / Network ---
# JSON-RPC URL (Alchemy, Infura, or local node)
RPC_URL=https://eth-.../v2/YOUR_KEY

# Optional: specify environment name (local|testnet|mainnet)
ENVIRONMENT=local

# --- Deployed contract addresses (fill after deploy) ---
LENDING_POOL_ADDRESS=0x0000000000000000000000000000000000000000
CDS_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
SETTLEMENT_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
CREDIT_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
MARGIN_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
PREMIUM_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000

# --- Keeper settings ---
# How often (seconds) the keeper polls for events
POLL_INTERVAL_SECS=1800
# How many confirmations to wait before acting on an event
CONFIRMATIONS=1
SETTLEMENT_CHUNK_SIZE=10

# --- Risk model API (optional, falls back to mock model if missing) ---
RISK_API_URL=
RISK_API_KEY=
RISK_API_TIMEOUT_SECS=15

# --- Optional / Advanced ---
# Chainlink feed for WETH/USD (used if Deploy.s.sol sets Chainlink feed)
CHAINLINK_WETH_USD=

# Optional backup key for CI/testing
PRIVATE_KEY_BACKUP=
